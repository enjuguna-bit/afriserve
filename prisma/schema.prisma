  id                  Int      @id @default(autoincrement())
  loan_id             Int
  collateral_asset_id Int
  forced_sale_value   Decimal?
  lien_rank           Int      @default(1)
  note                String?
  created_by_user_id  Int?
  created_at          DateTime

  loan             loans             @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  collateral_asset collateral_assets @relation(fields: [collateral_asset_id], references: [id], onDelete: Cascade)
  created_by_user  users?            @relation("LoanCollateralCreatedByUser", fields: [created_by_user_id], references: [id], onDelete: SetNull)

  @@unique([loan_id, collateral_asset_id])
  @@index([loan_id])
  @@index([collateral_asset_id])
  @@index([created_by_user_id])
  @@map("loan_collaterals")
}

// ---------------------------------------------------------------------------
// Idempotency key table for repayments.
// Guarantees that M-Pesa / mobile-money callbacks firing more than once
// cannot create duplicate repayment records. The unique constraint on
// (loan_id, client_idempotency_key) is the source-of-truth dedup lock.
// ---------------------------------------------------------------------------
model repayment_idempotency_keys {
  id                    Int      @id @default(autoincrement())
  loan_id               Int
  client_idempotency_key String
  repayment_id          Int?
  request_amount        Decimal
  created_at            DateTime
  updated_at            DateTime

  loan      loans       @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  repayment repayments? @relation(fields: [repayment_id], references: [id], onDelete: SetNull)

  @@unique([loan_id, client_idempotency_key])
  @@index([loan_id])
  @@index([repayment_id])
  @@map("repayment_idempotency_keys")
}

// ---------------------------------------------------------------------------
// Overpayment credit ledger.
// When a repayment exceeds the loan balance the surplus is held here as
// a credit that can be applied to a future loan or refunded.
// ---------------------------------------------------------------------------
model loan_overpayment_credits {
  id           Int      @id @default(autoincrement())
  loan_id      Int
  client_id    Int?
  branch_id    Int?
  repayment_id Int
  amount       Decimal
  /// open | applied | refunded
  status       String   @default("open")
  note         String?
  created_at   DateTime
  updated_at   DateTime

  loan      loans      @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  repayment repayments @relation(fields: [repayment_id], references: [id], onDelete: Cascade)

  @@index([loan_id])
  @@index([repayment_id])
  @@index([client_id])
  @@index([status], map: "idx_overpayment_credits_status")
  @@map("loan_overpayment_credits")
}
