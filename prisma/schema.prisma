  journal gl_journals @relation(fields: [journal_id], references: [id], onDelete: Restrict)
  account gl_accounts @relation(fields: [account_id], references: [id], onDelete: Restrict)

  @@index([journal_id])
  @@index([account_id])
  @@index([account_id, created_at], map: "idx_gl_entries_account_created_at")
  @@map("gl_entries")
}

model gl_fx_rates {
