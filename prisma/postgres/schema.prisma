  guarantor_id           Int
  guarantee_amount       Decimal  @default(0) @db.Decimal(18,4)
  relationship_to_client String?
  liability_type         String   @default("individual")
  note                   String?
  created_by_user_id     Int?
  created_at             DateTime @db.Timestamptz(3)
  tenant_id              String   @default("default")

  loan            loans      @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  guarantor       guarantors @relation(fields: [guarantor_id], references: [id], onDelete: Cascade)
  created_by_user users?     @relation("LoanGuarantorCreatedByUser", fields: [created_by_user_id], references: [id], onDelete: SetNull)

  @@unique([loan_id, guarantor_id])
  @@index([loan_id])
  @@index([guarantor_id])
  @@index([created_by_user_id])
  @@index([tenant_id, loan_id], map: "idx_loan_guarantors_tenant_loan")
  @@index([tenant_id, guarantor_id], map: "idx_loan_guarantors_tenant_guarantor")
  @@map("loan_guarantors")
}

model collateral_assets {
  id                  Int       @id @default(autoincrement())
  asset_type          String
  description         String
  estimated_value     Decimal @db.Decimal(18,4)
  ownership_type      String    @default("client")
  owner_name          String?
  owner_national_id   String?
  registration_number String?
  logbook_number      String?
  title_number        String?
  location_details    String?
  valuation_date      DateTime? @db.Timestamptz(3)
  document_url        String?
  image_urls_json     String?
  status              String    @default("active")
  client_id           Int?
  branch_id           Int?
  created_by_user_id  Int?
  created_at          DateTime @db.Timestamptz(3)
  updated_at          DateTime @db.Timestamptz(3)
  tenant_id           String    @default("default")

  client           clients?           @relation("ClientCollateralAssets", fields: [client_id], references: [id], onDelete: SetNull)
  branch           branches?          @relation("CollateralAssetBranch", fields: [branch_id], references: [id], onDelete: SetNull)
  created_by_user  users?             @relation("CollateralAssetCreatedByUser", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  loan_collaterals loan_collaterals[]

  @@index([client_id])
  @@index([branch_id])
  @@index([created_by_user_id])
  @@index([tenant_id, branch_id], map: "idx_collateral_assets_tenant_branch")
  @@index([tenant_id, status], map: "idx_collateral_assets_tenant_status")
  @@map("collateral_assets")
}

model loan_collaterals {
  id                  Int      @id @default(autoincrement())
  loan_id             Int
  collateral_asset_id Int
  forced_sale_value   Decimal? @db.Decimal(18,4)
  lien_rank           Int      @default(1)
  note                String?
  created_by_user_id  Int?
  created_at          DateTime @db.Timestamptz(3)
  tenant_id           String    @default("default")

  loan             loans             @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  collateral_asset collateral_assets @relation(fields: [collateral_asset_id], references: [id], onDelete: Cascade)
  created_by_user  users?            @relation("LoanCollateralCreatedByUser", fields: [created_by_user_id], references: [id], onDelete: SetNull)

  @@unique([loan_id, collateral_asset_id])
  @@index([loan_id])
  @@index([collateral_asset_id])
  @@index([created_by_user_id])
  @@index([tenant_id, loan_id], map: "idx_loan_collaterals_tenant_loan")
  @@index([tenant_id, collateral_asset_id], map: "idx_loan_collaterals_tenant_asset")
  @@map("loan_collaterals")
}

model client_profile_versions {
  id                 Int      @id @default(autoincrement())
  tenant_id          String   @default("default")
  client_id          Int
  version_number     Int
  based_on_refresh_id Int?
  snapshot_json      String
  note               String?
  created_by_user_id Int?
  approved_by_user_id Int?
  effective_from     DateTime @db.Timestamptz(3)
  created_at         DateTime @db.Timestamptz(3)

  client           clients @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by_user  users?  @relation("ClientProfileVersionCreatedByUser", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  approved_by_user users?  @relation("ClientProfileVersionApprovedByUser", fields: [approved_by_user_id], references: [id], onDelete: SetNull)

  @@unique([client_id, version_number])
  @@index([tenant_id, client_id], map: "idx_client_profile_versions_tenant_client")
  @@index([client_id, effective_from], map: "idx_client_profile_versions_client_effective")
  @@map("client_profile_versions")
}

model client_profile_refreshes {
  id                     Int      @id @default(autoincrement())
  tenant_id              String   @default("default")
  client_id              Int
  based_on_version_id    Int?
  based_on_version_number Int?
  approved_version_id    Int?
  status                 String   @default("draft")
  priority_status        String   @default("normal")
  requested_by_user_id   Int?
  assigned_to_user_id    Int?
  submitted_by_user_id   Int?
  reviewed_by_user_id    Int?
  requested_note         String?
  submission_note        String?
  review_note            String?
  locked_fields_json     String?
  editable_fields_json   String?
  active_snapshot_json   String
  draft_snapshot_json    String
  requested_at           DateTime @db.Timestamptz(3)
  submitted_at           DateTime? @db.Timestamptz(3)
  reviewed_at            DateTime? @db.Timestamptz(3)
  approved_at            DateTime? @db.Timestamptz(3)
  created_at             DateTime @db.Timestamptz(3)
  updated_at             DateTime @db.Timestamptz(3)
  pushback_count         Int      @default(0)

  client            clients                        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  requested_by_user users?                         @relation("ClientProfileRefreshRequestedByUser", fields: [requested_by_user_id], references: [id], onDelete: SetNull)
  assigned_to_user  users?                         @relation("ClientProfileRefreshAssignedToUser", fields: [assigned_to_user_id], references: [id], onDelete: SetNull)
  submitted_by_user users?                         @relation("ClientProfileRefreshSubmittedByUser", fields: [submitted_by_user_id], references: [id], onDelete: SetNull)
  reviewed_by_user  users?                         @relation("ClientProfileRefreshReviewedByUser", fields: [reviewed_by_user_id], references: [id], onDelete: SetNull)
  events            client_profile_refresh_events[]
  feedback          client_profile_refresh_feedback[]

  @@index([tenant_id, status, priority_status], map: "idx_client_profile_refreshes_tenant_status")
  @@index([assigned_to_user_id, status], map: "idx_client_profile_refreshes_assigned_status")
  @@map("client_profile_refreshes")
}

model client_profile_refresh_events {
  id                   Int      @id @default(autoincrement())
  tenant_id            String   @default("default")
  refresh_id           Int
  event_type           String
  field_path           String?
  actor_user_id        Int?
  previous_value_json  String?
  next_value_json      String?
  reason               String?
  gps_latitude         Float?
  gps_longitude        Float?
  gps_accuracy_meters  Float?
  device_captured_at   DateTime? @db.Timestamptz(3)
  metadata_json        String?
  created_at           DateTime @db.Timestamptz(3)

  refresh    client_profile_refreshes @relation(fields: [refresh_id], references: [id], onDelete: Cascade)
  actor_user users?                   @relation("ClientProfileRefreshEventActorUser", fields: [actor_user_id], references: [id], onDelete: SetNull)

  @@index([refresh_id, created_at], map: "idx_client_profile_refresh_events_refresh_created")
  @@map("client_profile_refresh_events")
}

model client_profile_refresh_feedback {
  id                  Int      @id @default(autoincrement())
  tenant_id           String   @default("default")
  refresh_id          Int
  field_path          String
  reason_code         String?
  comment             String?
  flagged_by_user_id  Int?
  resolved_by_user_id Int?
  flagged_at          DateTime @db.Timestamptz(3)
  resolved_at         DateTime? @db.Timestamptz(3)
  status              String   @default("open")

  refresh          client_profile_refreshes @relation(fields: [refresh_id], references: [id], onDelete: Cascade)
  flagged_by_user  users?                   @relation("ClientProfileRefreshFeedbackFlaggedByUser", fields: [flagged_by_user_id], references: [id], onDelete: SetNull)
  resolved_by_user users?                   @relation("ClientProfileRefreshFeedbackResolvedByUser", fields: [resolved_by_user_id], references: [id], onDelete: SetNull)

  @@index([refresh_id, status, field_path], map: "idx_client_profile_refresh_feedback_refresh_status")
  @@map("client_profile_refresh_feedback")
}

// ---------------------------------------------------------------------------
// Idempotency key table for repayments.
// Guarantees that M-Pesa / mobile-money callbacks firing more than once
// cannot create duplicate repayment records. The unique constraint on
// (loan_id, client_idempotency_key) is the source-of-truth dedup lock.
// ---------------------------------------------------------------------------
model repayment_idempotency_keys {
  id                    Int      @id @default(autoincrement())
  tenant_id             String   @default("default")
  loan_id               Int
  client_idempotency_key String
  repayment_id          Int?
  request_amount        Decimal @db.Decimal(18,4)
  created_at            DateTime @db.Timestamptz(3)
  updated_at            DateTime @db.Timestamptz(3)

  loan      loans       @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  repayment repayments? @relation(fields: [repayment_id], references: [id], onDelete: SetNull)

  @@unique([loan_id, client_idempotency_key])
  @@index([loan_id])
  @@index([repayment_id])
  @@index([tenant_id], map: "idx_repayment_idempotency_tenant_id")
  @@map("repayment_idempotency_keys")
}

// ---------------------------------------------------------------------------
// Overpayment credit ledger.
// When a repayment exceeds the loan balance the surplus is held here as
// a credit that can be applied to a future loan or refunded.
// ---------------------------------------------------------------------------
model loan_overpayment_credits {
  id           Int      @id @default(autoincrement())
  tenant_id    String   @default("default")
  loan_id      Int
  client_id    Int?
  branch_id    Int?
  repayment_id Int
  amount       Decimal @db.Decimal(18,4)
  /// open | applied | refunded
  status       String   @default("open")
  note         String?
  created_at   DateTime @db.Timestamptz(3)
  updated_at   DateTime @db.Timestamptz(3)

  loan      loans      @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  repayment repayments @relation(fields: [repayment_id], references: [id], onDelete: Cascade)

  @@index([loan_id])
  @@index([repayment_id])
  @@index([client_id])
  @@index([status], map: "idx_overpayment_credits_status")
  @@index([tenant_id], map: "idx_loan_overpayment_credits_tenant_id")
  @@unique([repayment_id], map: "idx_loan_overpayment_credit_repayment_id")
  @@map("loan_overpayment_credits")
}
