VITE_APP_ENV=development
VITE_SENTRY_DSN=
VITE_GA_ID=
VITE_LOG_LEVEL=warn
# Frontend runtime API base URL.
# For local Vite dev with proxy, keep as /api.
VITE_API_BASE_URL=/api

# Axios timeout (milliseconds)
VITE_API_TIMEOUT_MS=15000

# Vite dev proxy target to backend API server
VITE_API_PROXY_TARGET=http://localhost:4000
