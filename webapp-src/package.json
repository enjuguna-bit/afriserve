{
  "name": "afriservebackend",
  "version": "1.0.0",
  "description": "Microfinance backend API",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "node scripts/prisma-manager.mjs generate-clients && tsc -p tsconfig.json && node scripts/copy-public.mjs",
    "build:frontend": "node scripts/build-frontend.mjs",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/src/worker.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "test": "npm run build:server && node --test dist/tests/**/*.test.js",
    "test:precision": "npm run build:server && node --test dist/tests/financial-precision-regression.test.js",
    "migrate": "npm run build:server && node dist/scripts/migrate.js up",
    "migrate:dev": "node scripts/prisma-manager.mjs migrate-dev",
    "migrate:reset": "node scripts/prisma-manager.mjs migrate-reset",
    "migrate:kyc": "npm run build:server && node dist/scripts/migrate_kyc.js",
    "migrate:postgres": "npm run build:server && node dist/scripts/migrate_sqlite_to_postgres.js",
    "postinstall": "node scripts/prisma-manager.mjs generate-clients",
    "lint": "eslint src scripts tests",
    "format": "prettier --write src scripts tests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json",
    "prisma:generate": "node scripts/prisma-manager.mjs generate-clients",
    "prisma:migrate": "node scripts/prisma-manager.mjs db-push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^6.16.2",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.61.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.38.0",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "prisma": "^6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
