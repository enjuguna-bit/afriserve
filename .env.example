
# =============================================================================
# AfriserveBackend — environment configuration template
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control — it is listed in .gitignore.
#
# ⚠ SECURITY CRITICAL — read before deploying:
#   1. JWT_SECRET must be a long, random, secret string unique per environment.
#      Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   2. ALLOW_CONSOLE_RESET_TOKENS=false in all non-local environments.
#      true prints password reset tokens to stdout — any log access = account takeover.
#   3. REQUIRE_VERIFIED_CLIENT_KYC_FOR_LOAN_APPROVAL=true in production.
#      false bypasses AML/fraud KYC controls on loan approval.
#   4. Change all default passwords (RABBITMQ_PASS, POSTGRES_PASSWORD, etc.)
#      before deploying to any shared or production environment.
# =============================================================================

PORT=3000

# ── Authentication ─────────────────────────────────────────────────────────────
# Required. Must be long and random. Never use the placeholder value in any
# environment beyond a single-developer local machine.
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64_hex
# Space-separated list of additional valid secrets for zero-downtime rotation.
JWT_SECRETS=
AUTH_TOKEN_STORE_REDIS_URL=
AUTH_SESSION_CACHE_REDIS_URL=
AUTH_SESSION_CACHE_TTL_SECONDS=60
RATE_LIMIT_REDIS_URL=

# ── Network ───────────────────────────────────────────────────────────────────
# Set to true when running behind a load balancer or reverse proxy (Azure App Service,
# nginx, etc.) so Express reads the real client IP from X-Forwarded-For.
# MUST be true in production behind a proxy; leave false only for direct-internet deployments.
TRUST_PROXY=false
API_BASE_URL=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_HTTP_SAMPLE_RATE=
LOG_SHIPPER_ENABLED=false
LOG_SHIPPER_URL=
LOG_SHIPPER_AUTH_TOKEN=
LOG_SHIPPER_MIN_LEVEL=warn
LOG_SHIPPER_TIMEOUT_MS=3000

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
UPTIME_HEARTBEAT_URL=
UPTIME_HEARTBEAT_INTERVAL_MS=60000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_NO_ORIGIN=
ADMIN_IP_WHITELIST=

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=
DB_CLIENT=sqlite
ALLOW_SQLITE_IN_PRODUCTION=false
DATABASE_URL=
DATABASE_READ_URL=
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
PG_READ_POOL_MAX=20
PG_READ_IDLE_TIMEOUT_MS=30000
PG_READ_CONNECTION_TIMEOUT_MS=5000

# ── HTTPS ─────────────────────────────────────────────────────────────────────
HTTPS_ENFORCE_IN_PRODUCTION=true
HTTPS_ENFORCEMENT_MODE=reject
HTTPS_TRUST_FORWARDED_PROTO=true
HTTPS_REDIRECT_STATUS_CODE=308

# ── Database backup ───────────────────────────────────────────────────────────
DB_BACKUP_ENABLED=false
DB_BACKUP_DIR=
DB_BACKUP_INTERVAL_MS=21600000
DB_BACKUP_RETENTION_COUNT=14

# ── BullMQ job queue ──────────────────────────────────────────────────────────
JOB_QUEUE_ENABLED=false
JOB_QUEUE_REDIS_URL=
JOB_QUEUE_NAME=afriserve-system-jobs
JOB_QUEUE_DLQ_NAME=afriserve-system-jobs:dead-letter
JOB_QUEUE_CONCURRENCY=4
JOB_QUEUE_ATTEMPTS=5

# ── Report cache ──────────────────────────────────────────────────────────────
REPORT_CACHE_ENABLED=false
REPORT_CACHE_TTL_MS=15000
REPORT_CACHE_STRATEGY=memory
REPORT_CACHE_REDIS_URL=

# ── Report delivery ───────────────────────────────────────────────────────────
REPORT_DELIVERY_ENABLED=false
REPORT_DELIVERY_INTERVAL_MS=86400000
REPORT_DELIVERY_RECIPIENT_EMAIL=
REPORT_DELIVERY_WEBHOOK_URL=
REPORT_DELIVERY_WEBHOOK_TIMEOUT_MS=5000

# ── Password reset ────────────────────────────────────────────────────────────
PASSWORD_RESET_WEBHOOK_URL=
PASSWORD_RESET_WEBHOOK_TIMEOUT_MS=5000

# ── Background job intervals ──────────────────────────────────────────────────
OVERDUE_SYNC_INTERVAL_MS=60000

# ── Accounting ────────────────────────────────────────────────────────────────
ACCOUNTING_BATCH_ENABLED=true
ACCOUNTING_BATCH_INTERVAL_MS=21600000

# Accounting GL subscriber consumer.
# Set ACCOUNTING_GL_SHADOW_MODE=true during initial rollout to log GL events
# without posting real journal entries (safe cutover mode).
# Set ACCOUNTING_GL_CONSUMER_ENABLED=true only when EVENT_BROKER_PROVIDER=rabbitmq.
ACCOUNTING_GL_SHADOW_MODE=true
ACCOUNTING_GL_CONSUMER_ENABLED=false
# Queue name the GL subscriber listens on. Must not contain spaces.
RABBITMQ_ACCOUNTING_QUEUE=afriserve.accounting

# ── Hierarchy ─────────────────────────────────────────────────────────────────
HIERARCHY_CACHE_TTL_MS=30000

# ── Security flags ────────────────────────────────────────────────────────────
# ⚠ MUST be false in all non-local environments.
# When true, password reset tokens are printed to stdout — any log access gives
# an attacker the ability to reset any user's password.
ALLOW_CONSOLE_RESET_TOKENS=false

# ⚠ MUST be true in all production environments.
# When false, loans can be approved for clients who have not passed KYC
# verification, bypassing AML and fraud controls.
REQUIRE_VERIFIED_CLIENT_KYC_FOR_LOAN_APPROVAL=true

ALLOW_CONCURRENT_LOANS=false

# ── Mobile money ──────────────────────────────────────────────────────────────
MOBILE_MONEY_PROVIDER=mock
MOBILE_MONEY_C2B_ENABLED=false
MOBILE_MONEY_B2C_ENABLED=false
MOBILE_MONEY_B2C_CORE_RETRY_ENABLED=true
MOBILE_MONEY_B2C_CORE_RETRY_INTERVAL_MS=60000
MOBILE_MONEY_B2C_CORE_RETRY_MIN_AGE_MS=30000
MOBILE_MONEY_B2C_CORE_RETRY_BATCH_SIZE=25
MOBILE_MONEY_STK_ENABLED=false
MOBILE_MONEY_WEBHOOK_TOKEN=
MOBILE_MONEY_CALLBACK_IP_WHITELIST=196.201.214.200,196.201.214.206,196.201.213.114,196.201.214.207,196.201.214.208,196.201.213.44,196.201.212.127,196.201.212.138,196.201.212.129,196.201.212.136,196.201.212.74,196.201.212.69
MOBILE_MONEY_DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
MOBILE_MONEY_DARAJA_CONSUMER_KEY=
MOBILE_MONEY_DARAJA_CONSUMER_SECRET=
MOBILE_MONEY_DARAJA_OAUTH_PATH=/oauth/v1/generate
MOBILE_MONEY_DARAJA_B2C_PAYMENT_PATH=/mpesa/b2c/v1/paymentrequest
MOBILE_MONEY_DARAJA_B2C_INITIATOR_NAME=
MOBILE_MONEY_DARAJA_B2C_SECURITY_CREDENTIAL=
MOBILE_MONEY_DARAJA_B2C_SHORTCODE=
MOBILE_MONEY_DARAJA_B2C_COMMAND_ID=BusinessPayment
MOBILE_MONEY_DARAJA_B2C_RESULT_URL=
MOBILE_MONEY_DARAJA_B2C_TIMEOUT_URL=
MOBILE_MONEY_DARAJA_STK_PUSH_PATH=/mpesa/stkpush/v1/processrequest
MOBILE_MONEY_DARAJA_STK_SHORTCODE=174379
MOBILE_MONEY_DARAJA_STK_PASSKEY=
MOBILE_MONEY_DARAJA_STK_CALLBACK_URL=
MOBILE_MONEY_DARAJA_STK_TRANSACTION_TYPE=CustomerPayBillOnline

# ── Event broker ──────────────────────────────────────────────────────────────
EVENT_BROKER_PROVIDER=none
EVENT_BROKER_URL=
EVENT_TOPIC_PREFIX=afriserve
EVENT_DISPATCH_INLINE=true
DOMAIN_EVENT_DISPATCH_ENABLED=true
DOMAIN_EVENT_DISPATCH_INTERVAL_MS=10000
DOMAIN_EVENT_DISPATCH_BATCH_SIZE=100

# -- RabbitMQ consumer (notifications) -----------------------------------------
# Only active when EVENT_BROKER_PROVIDER=rabbitmq.
# RABBITMQ_URL overrides EVENT_BROKER_URL for the consumer connection string.
RABBITMQ_URL=
RABBITMQ_USER=afriserve
# ⚠ Change RABBITMQ_PASS before deploying to any shared environment.
RABBITMQ_PASS=CHANGE_ME_rabbitmq_password
# Queue name for borrower notification events. Defaults to afriserve.notifications
RABBITMQ_CONSUMER_QUEUE=
# Delivery attempts before a message is dead-lettered.
RABBITMQ_CONSUMER_MAX_RETRIES=5

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
# Tenant ID used by background jobs and as the fallback when X-Tenant-ID header
# is absent. In single-tenant deployments this is always 'default'.
DEFAULT_TENANT_ID=default

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_STORAGE_DRIVER=local
UPLOAD_LOCAL_DIR=
UPLOAD_PUBLIC_BASE_PATH=/uploads
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_S3_ENDPOINT=
UPLOAD_S3_BUCKET=
UPLOAD_S3_REGION=us-east-1
UPLOAD_S3_ACCESS_KEY_ID=
UPLOAD_S3_SECRET_ACCESS_KEY=
UPLOAD_S3_FORCE_PATH_STYLE=true
UPLOAD_S3_PUBLIC_BASE_URL=
