# ── Root-level debug / scratch files ──────────────────────────────────────────
# These are temporary build-output captures and manual test logs that
# accumulate during development and must never be committed.

# Build output captures  (build_*.txt, build_*.log)
/build_*.txt
/build_*.log

# TSC output captures
/tsc*.txt
/tsc*.log

# Server runtime & error logs
/server*.txt
/server*.log
/server-runtime*.log
/server-runtime*.err

# Test run output
/test_*.txt
/test_*.log
/test_*.js
/test-results.json
/fresh_test_*.txt
/fresh_test_*.log
/final_test*.txt
/final_verification.txt
/eval_test.txt

# TAP output
/tap*.txt
/tap*.log

# Gap / diff analysis files
/gap*.txt
/gap*.log

# Error / strict-error captures
/err*.txt
/err*.log
/strict_errors*.txt
/postgres-err.txt
/plan-err.txt

# Mobile money debug
/mobile*.txt
/mobile*.log
/topup_debug*.log

# Loan / hierarchy debug
/loan*.txt
