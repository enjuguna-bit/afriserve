/webapp-runtime-live/
/webapp-source-live/
/webapp-staging-live/
/aca-build-context-*/
/appservice-logs-*/
/docx_tmp/

# Android specific junk
**/.gradle/
**/.gradle-home/
**/.gradle-user-home/
**/.kotlin/
**/build/
**/local.properties

# Whitelist important files if they match above patterns
!/package.json
!/package-lock.json
!/.github/workflows/*.yml
!/src/**/*.ts
!/webapp-src/**/*.ts
!/android-customer-app/app/src/**/*.xml
!/android-loan-officer-app/app/src/**/*.xml
!/android-customer-app/app/src/**/*.kt
!/android-loan-officer-app/app/src/**/*.kt
!/android-customer-app/*.gradle.kts
